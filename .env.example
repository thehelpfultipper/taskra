# Database connection string for server-side tooling only.
# For local Supabase CLI this is usually:
# postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# ---------------------------------------------------------------------------
# Supabase (browser-safe)
# ---------------------------------------------------------------------------
# Safe to expose to browser clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Supabase (server-only secret)
# ---------------------------------------------------------------------------
# NEVER expose this to browser bundles. Use only in trusted server contexts.
SUPABASE_SERVICE_ROLE_KEY=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
